{
  "name": "lava-payment/lava",
  "type": "library",
  "description": "Lava Payment SDK",
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "prefer-stable": true,
  "keywords": [
    "lava",
    "lava-sdk",
    "lava payment"
  ],
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Lava\\Api\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Test\\Lava\\Api\\": "tests/"
    }
  },
  "require": {
    "php": ">= 7.4  || >=8.0",
    "ext-json": "*"
  },
  "require-dev": {
    "ext-curl": "*",
    "phpunit/phpunit": "^9.5",
    "mockery/mockery": "^1.5.1",
    "vimeo/psalm": "^4.29"
  }
}
